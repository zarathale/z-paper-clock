\f4\i \cf0 Why:
\f0\i0  Top row + bottom row of the PNG are full-width opaque white. Those pixels render as bright white lines at every slab's outer-edge texture sample. The fix is to zero alpha on the 4 PNG borders before THREE.js sees the image. Source PNG is unchanged on disk.\
Current:\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 const scanTex = new THREE.TextureLoader().load(SCAN_DATA_URL);\
scanTex.flipY  = false;\
\pard\pardeftab720\sa240\partightenfactor0

\f0\fs24 \cf0 Proposed replacement:\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 // Strip the 1-px opaque-white border baked into source/pieces/069.png\
// (Affinity export artifact \'97 top + bottom rows + corner pixels are RGBA(255,255,255,255)\
// and would render as white lines at every slab's outer texture edge).\
const scanTex = new THREE.Texture();\
scanTex.flipY = false;\
const _scanImg = new Image();\
_scanImg.onload = function () \{\
  const c = document.createElement('canvas');\
  c.width = _scanImg.width; c.height = _scanImg.height;\
  const ctx = c.getContext('2d');\
  ctx.drawImage(_scanImg, 0, 0);\
  const id = ctx.getImageData(0, 0, c.width, c.height);\
  const d = id.data, W = c.width, H = c.height;\
  for (let x = 0; x < W; x++) \{                       // top + bottom rows\
    d[(0 * W + x) * 4 + 3] = 0;\
    d[((H - 1) * W + x) * 4 + 3] = 0;\
  \}\
  for (let y = 0; y < H; y++) \{                       // left + right columns\
    d[(y * W + 0)         * 4 + 3] = 0;\
    d[(y * W + (W - 1))   * 4 + 3] = 0;\
  \}\
  ctx.putImageData(id, 0, 0);\
  scanTex.image = c;\
  scanTex.needsUpdate = true;\
\};\
_scanImg.src = SCAN_DATA_URL;\
\pard\pardeftab720\partightenfactor0

