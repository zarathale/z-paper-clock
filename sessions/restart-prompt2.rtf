\f1\b \cf0 \strokec2 Edit 3 \'97 two-phase fold animation
\f0\b0  (replaces current 
\f2\fs26 applyFold
\f0\fs24  around line 268)\
\pard\pardeftab720\sa240\partightenfactor0

\f4\i \cf0 Why:
\f0\i0  You picked two-phase earlier. Walls fold up over the 0\'9650% slider range, tabs fold inward over 50\'96100%. Sign of each ext rotation matches its parent wall pivot.\
Current:\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 function applyFold(t) \{\
  const a = (Math.PI / 2) * t;\
  pivots.leftPivot.rotation.y   =  a;\
  pivots.rightPivot.rotation.y  = -a;\
  pivots.topPivot.rotation.x    =  a;\
  pivots.bottomPivot.rotation.x = -a;\
\}\
\pard\pardeftab720\sa240\partightenfactor0

\f0\fs24 \cf0 Proposed:\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 function applyFold(t) \{\
  // Two-phase: 0\'9650% folds the 4 walls up; 50\'96100% folds the 4 tabs inward.\
  const wallT = Math.min(t * 2, 1);                // 0..1 over t in [0, 0.5]\
  const extT  = Math.max(t * 2 - 1, 0);            // 0..1 over t in [0.5, 1]\
  const wallA = (Math.PI / 2) * wallT;\
  const extA  = (Math.PI / 2) * extT;\
  pivots.leftPivot.rotation.y       =  wallA;\
  pivots.rightPivot.rotation.y      = -wallA;\
  pivots.topPivot.rotation.x        =  wallA;\
  pivots.bottomPivot.rotation.x     = -wallA;\
  pivots.leftExtPivot.rotation.y    =  extA;\
  pivots.rightExtPivot.rotation.y   = -extA;\
  pivots.topExtPivot.rotation.x     =  extA;\
  pivots.bottomExtPivot.rotation.x  = -extA;\
\}\
\pard\pardeftab720\partightenfactor0

